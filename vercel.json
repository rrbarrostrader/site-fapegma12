{
  "version": 2,
  "buildCommand": "cp -r público/teologia /tmp/teologia-backup && npm run build && cp -r /tmp/teologia-backup público/teologia",
  "outputDirectory": "público",
  "framework": null,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/teologia", "destination": "/teologia/index.html" },
    { "source": "/teologia/", "destination": "/teologia/index.html" },
    { "source": "/teologia/index.html", "destination": "/teologia/index.html" },
    { "source": "/((?!teologia).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/teologia/assets/video-hero.mp4",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/teologia/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
