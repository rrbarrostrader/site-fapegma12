{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/teologia/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/teologia",
      "destination": "/teologia/index.html"
    },
    {
      "source": "/teologia/",
      "destination": "/teologia/index.html"
    }
  ]
}
