{
  "version": 2,
  "builds": [
    {
      "src": "cliente/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "pnpm install",
        "buildCommand": "pnpm --filter cliente build"
      }
    },
    {
      "src": "servidor/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**"]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/servidor"
    }
  ]
}
